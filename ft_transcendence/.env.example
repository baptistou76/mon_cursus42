# Root-level example env. Copy to .env and adjust per environment.
# Backend service
JWT_SECRET=change_me_to_a_strong_random_string
PORT=3000
NODE_ENV=development
COOKIE_DOMAIN=localhost
CORS_ORIGIN=https://localhost:443
# If using OAuth 42, include client credentials here (do not commit real values)
OAUTH42_CLIENT_ID=
OAUTH42_CLIENT_SECRET=
OAUTH42_REDIRECT_URI=https://localhost:443/auth/callback

# Frontend service
# Must be HTTPS in production to enforce WSS for WebSocket
VITE_API_URL=https://localhost:443/api
